{
  "name": "bee-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram bot for beekeeping queen breeding calendar",
  "main": "main.js",
  "scripts": {
    "start": "set NODE_ENV=development&& electron .",
    "build": "electron-builder",
    "build:nsis": "electron-builder --win nsis",
    "build:dir": "electron-builder --win --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.61.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-rebuild": "^3.2.9"
  },
  "keywords": ["telegram", "bot", "beekeeping", "calendar"],
  "author": "",
  "license": "GPL-3.0",
  "build": {
    "appId": "com.bee.calendar",
    "productName": "Bee Telegram Bot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!php/**/*",
      "!data/*.db",
      "!logs/*.log",
      "!dist/**/*",
      "!node_modules/.cache/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bee Telegram Bot",
      "runAfterFinish": true
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      }
    ]
  }
}